# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://dtl_user:password@localhost:5432/dtl_db

# ── JWT auth ─────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS (comma-separated origins) ───────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.xyz,https://www.yourdomain.xyz

# ── Claude AI (https://console.anthropic.com → API Keys) ────────────────────
# Required for: TTN OCR, NL→SQL assistant, anomaly detection
ANTHROPIC_API_KEY=sk-ant-...
# Optional: proxy URL if direct access to api.anthropic.com is blocked
# ANTHROPIC_BASE_URL=https://anthropic-proxy.yourname.workers.dev
